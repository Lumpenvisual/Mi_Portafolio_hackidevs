---
// Sobre mí — presentación con avatar pixel art y stack tecnológico
const tecnologias = [
  { nombre: 'HTML', icono: '🟧' },
  { nombre: 'CSS', icono: '🟦' },
  { nombre: 'JavaScript', icono: '🟨' },
  { nombre: 'Python', icono: '🐍' },
  { nombre: 'Git', icono: '🔀' },
];
---

<section id="sobre-mi" class="sobre-mi">
  <div class="contenedor sobre-mi__grid">

    <!-- Columna de texto -->
    <div class="sobre-mi__texto fade-up">
      <h2 class="titulo-seccion">Sobre mí</h2>
      <div class="linea-acento"></div>
      <p>
        Soy <strong>comunicadora audiovisual</strong> con más de 10 años narrando historias que importan.
        Hoy también construyo flujos de trabajo con <strong>inteligencia artificial</strong>
        para hacer que esas historias lleguen más lejos.
      </p>
      <p>
        Estudio <strong>Análisis y Desarrollo de Software</strong> porque las mejores
        narrativas del futuro se escriben con código.
      </p>

      <!-- Stack -->
      <div class="sobre-mi__stack">
        <p class="stack__etiqueta">Tecnologías que estoy aprendiendo</p>
        <ul class="stack__lista">
          {tecnologias.map((t) => (
            <li class="stack__item">
              <span aria-hidden="true" class="stack__icono">{t.icono}</span>
              <span>{t.nombre}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Columna del avatar -->
    <div class="sobre-mi__avatar-wrap fade-up">
      <div class="avatar-frame" id="avatar-frame">
        <img
          src="/Hackidev.png"
          alt="Foto de perfil de Jacky Gutiérrez"
          class="avatar-img"
          id="avatar-img"
          width="260"
          height="260"
        />
        <div class="avatar-glow" aria-hidden="true"></div>
      </div>
      <p class="avatar-nombre">@hackidevs</p>
    </div>

  </div>
</section>

<style>
  .sobre-mi {
    padding: 7rem 0;
    background: var(--color-superficie);
  }

  .sobre-mi__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .sobre-mi__grid {
      grid-template-columns: 1fr 300px;
    }
  }

  .sobre-mi__texto p {
    color: var(--color-texto-suave);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .sobre-mi__texto strong {
    color: var(--color-acento-claro);
    font-weight: 500;
  }

  /* Stack */
  .stack__etiqueta {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-acento);
    margin-bottom: 1rem;
    margin-top: 0.5rem;
  }

  .stack__lista {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
  }

  .stack__item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--color-borde);
    font-size: 0.85rem;
    color: var(--color-texto);
    background: var(--color-fondo);
    transition: border-color 0.2s;
  }

  .stack__item:hover {
    border-color: var(--color-acento);
  }

  /* Avatar */
  .sobre-mi__avatar-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .avatar-frame {
    position: relative;
    width: 260px;
    height: 260px;
    overflow: hidden;
  }

  .avatar-img {
    width: 260px;
    height: 260px;
    display: block;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 0.5s ease;
    will-change: transform, filter;
  }

  .avatar-frame:hover .avatar-img {
    transform: scale(1.06);
    filter: brightness(1.08) contrast(1.05);
  }

  .avatar-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(139,92,246,0.22) 0%, transparent 65%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .avatar-frame:hover .avatar-glow {
    opacity: 1;
  }

  .avatar-nombre {
    font-size: 0.85rem;
    color: var(--color-acento);
    letter-spacing: 0.1em;
    font-family: var(--fuente-cuerpo);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#sobre-mi .fade-up', {
    scrollTrigger: { trigger: '#sobre-mi', start: 'top 75%' },
    opacity: 1,
    y: 0,
    stagger: 0.2,
    duration: 0.8,
    ease: 'power3.out',
  });

  // Glow que sigue el cursor dentro del avatar
  const frame = document.getElementById('avatar-frame');
  const glow = frame?.querySelector('.avatar-glow') as HTMLElement | null;

  frame?.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = frame.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width) * 100;
    const y = ((e.clientY - rect.top) / rect.height) * 100;
    if (glow) {
      glow.style.setProperty('--mx', `${x}%`);
      glow.style.setProperty('--my', `${y}%`);
    }
  });
</script>
