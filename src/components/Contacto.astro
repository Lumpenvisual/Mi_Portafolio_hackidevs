---
// Contacto — links sociales + formulario vía Formspree
// Reemplaza ACTION_FORMSPREE con tu endpoint de formspree.io (ej: https://formspree.io/f/xyzabcde)
const ACTION_FORMSPREE = 'https://formspree.io/f/TU_ID_AQUI';

const redes = [
  {
    nombre: 'GitHub',
    url: 'https://github.com/hackidevs',
    icono: `<svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  },
  {
    nombre: 'LinkedIn',
    url: 'https://linkedin.com/in/jackygutierrez',
    icono: `<svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    nombre: 'YouTube',
    url: 'https://youtube.com/@hackidevs',
    icono: `<svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
];
---

<section id="contacto" class="contacto">
  <div class="contenedor contacto__inner">

    <div class="contacto__encabezado fade-up">
      <h2 class="titulo-seccion">Hablemos</h2>
      <div class="linea-acento"></div>
      <p class="contacto__desc">
        Ya sea para colaborar, preguntar algo o simplemente saludar —
        estoy aquí.
      </p>
    </div>

    <div class="contacto__grid">
      <!-- Redes sociales -->
      <div class="contacto__redes fade-up">
        <p class="redes__titulo">Encuéntrame en</p>
        <ul class="redes__lista">
          {redes.map((red) => (
            <li>
              <a href={red.url} target="_blank" rel="noopener noreferrer" class="red__link">
                <span set:html={red.icono} aria-hidden="true" class="red__icono" />
                <span>{red.nombre}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Formulario Formspree -->
      <form
        action={ACTION_FORMSPREE}
        method="POST"
        class="formulario fade-up"
        id="form-contacto"
      >
        <div class="campo">
          <label for="nombre">Nombre</label>
          <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
        </div>
        <div class="campo">
          <label for="email">Correo</label>
          <input type="email" id="email" name="email" required placeholder="tu@correo.com" />
        </div>
        <div class="campo">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" required placeholder="Escribe tu mensaje..."></textarea>
        </div>
        <button type="submit" class="btn-primario">Enviar mensaje</button>
        <p class="formulario__aviso" id="aviso-envio" aria-live="polite"></p>
      </form>
    </div>

  </div>
</section>

<style>
  .contacto {
    padding: 7rem 0;
    background: var(--color-superficie);
  }

  .contacto__inner {
    max-width: 900px;
  }

  .contacto__desc {
    color: var(--color-texto-suave);
    margin-bottom: 3rem;
  }

  .contacto__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .contacto__grid {
      grid-template-columns: 220px 1fr;
      align-items: start;
    }
  }

  /* Redes */
  .redes__titulo {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-acento);
    margin-bottom: 1.25rem;
  }

  .redes__lista {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .red__link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-texto-suave);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .red__link:hover {
    color: var(--color-acento);
  }

  .red__icono {
    display: flex;
    align-items: center;
  }

  /* Formulario */
  .formulario {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .campo {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .campo label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-texto-suave);
  }

  .campo input,
  .campo textarea {
    background: var(--color-fondo);
    border: 1px solid var(--color-borde);
    color: var(--color-texto);
    font-family: var(--fuente-cuerpo);
    font-size: 0.95rem;
    padding: 0.65rem 0.9rem;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }

  .campo input:focus,
  .campo textarea:focus {
    border-color: var(--color-acento);
  }

  .campo input::placeholder,
  .campo textarea::placeholder {
    color: #4a4a4a;
  }

  .formulario__aviso {
    font-size: 0.85rem;
    color: var(--color-acento-claro);
    min-height: 1.2em;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#contacto .fade-up', {
    scrollTrigger: { trigger: '#contacto', start: 'top 75%' },
    opacity: 1,
    y: 0,
    stagger: 0.15,
    duration: 0.8,
    ease: 'power3.out',
  });

  // Feedback del formulario sin recarga de página
  const form = document.getElementById('form-contacto') as HTMLFormElement;
  const aviso = document.getElementById('aviso-envio')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        aviso.textContent = 'Mensaje enviado. ¡Gracias!';
        form.reset();
      } else {
        aviso.textContent = 'Ocurrió un error. Inténtalo de nuevo.';
      }
    } catch {
      aviso.textContent = 'Sin conexión. Inténtalo más tarde.';
    }
  });
</script>
